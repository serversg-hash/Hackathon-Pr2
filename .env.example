# ==============================================================================
# MaintainIQ - Environment Configuration Example
# Copy this file to '.env' and populate actual credentials for your environment.
# ==============================================================================

# Network settings
PORT=3000
NODE_ENV=development

# Database Configuration (supports local mock store out-of-the-box if left blank)
# To use MongoDB/Mongoose:
MONGO_URI=mongodb://localhost:27017/maintainiq

# Security settings
JWT_SECRET=your_super_secret_enterprise_signature_key_here
JWT_EXPIRES_IN=24h

# Google Gemini API Key (Server-side proxy usage only)
GEMINI_API_KEY=

# SMTP Mail Configuration (For sending real OTP/forgot password emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional: Firebase Authentication Admin SDK settings (Used for real Bearer tokens verify)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
